# =============================================
# AVISAUTO.fr - Variables d'environnement
# =============================================

# Base de données (Supabase = PostgreSQL)
# Obtenir dans Supabase: Paramètres > Base de données > URI de connexion
# Format: postgresql://postgres.[projet-ref]:[mot-de-passe]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Session Express (générer une clé aléatoire en production)
SESSION_SECRET=votre-secret-session-changez-en-production

# OpenAI (pour les réponses IA)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optionnel: Apify dataset par défaut (sinon configurable par entreprise)
# L'URL peut aussi être définie dans les paramètres de chaque entreprise
APIFY_DATASET_URL=https://api.apify.com/v2/datasets/UOHrMRobcbbf5P1Vs/items?format=json

# Dev local
PORT=5000
BASE_PATH=/

# Frontend (pour Vite dev)
# L'API est proxifiée vers le backend sur le PORT ci-dessus
VITE_PORT=5173
